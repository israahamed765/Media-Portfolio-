# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is automatically injected at runtime from secrets.
# Configure this via your environment variables / secrets panel.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# This is automatically injected at runtime with the host URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
